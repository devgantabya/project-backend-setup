{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "module": "ESnext",
    "moduleResolution": "bundler",
    "target": "ESnext",

    "sourceMap": true,

    "strict": true,
    "skipLibCheck": true,

    "isolatedModules": true,
    "moduleDetection": "force",

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

  }
}
